# ─────────────────────────────────────────────────────────────────────────────
# Ezra Health QA — Environment Variables
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to source control — it contains credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Target environment — change to point at UAT or production
EZRA_BASE_URL=https://myezra-staging.ezra.com

# ── Member A (Attacker in security tests) ────────────────────────────────────
MEMBER_A_EMAIL=member-a@example.com
MEMBER_A_PASSWORD=YourPasswordHere
MEMBER_A_ID=member-a-uuid-here
MEMBER_A_TOKEN=eyJhbGci...   # JWT from login response

# ── Member B (Victim — data must be protected from Member A) ─────────────────
MEMBER_B_EMAIL=member-b@example.com
MEMBER_B_PASSWORD=YourPasswordHere
MEMBER_B_ID=member-b-uuid-here
MEMBER_B_TOKEN=eyJhbGci...
MEMBER_B_BOOKING_ID=booking-uuid-here
MEMBER_B_ENCOUNTER_ID=encounter-uuid-here

# ── Optional: path to pre-seeded auth state (set by global-setup.ts) ────────
# EZRA_STORAGE_STATE=.auth/member-a.json
