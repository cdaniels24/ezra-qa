{
  "name": "ezra-qa",
  "version": "1.0.0",
  "description": "Ezra Health QA Automation Suite — Playwright + TypeScript",
  "scripts": {
    "test":         "playwright test",
    "test:ui":      "playwright test --project=ui-chromium",
    "test:api":     "playwright test --project=api",
    "test:headed":  "playwright test --project=ui-chromium --headed",
    "test:smoke":   "playwright test --project=api",
    "report":       "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
